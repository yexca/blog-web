&lt;/div>
&lt;style lang="scss">
.notice {
padding: 0.75em 1em;
margin: 1em 0;
border-left: 4px solid;
border-radius: 4px;
background-color: var(--card-background-secondary);
color: var(--card-text-color-main);
backdrop-filter: saturate(var(--glass-saturation)) blur(var(--glass-blur));
-webkit-backdrop-filter: saturate(var(--glass-saturation)) blur(var(--glass-blur));
&amp;.default {
border-color: #ccc;
}
&amp;.info {
border-color: #2196f3;
color: #1a237e;
}
&amp;.warn {
border-color: #ff9800;
color: #e65100;
}
&amp;.danger {
border-color: #f44336;
color: #b71c1c;
}
}
[data-scheme="dark"] {
.notice {
&amp;.default {
border-color: #666;
color: #eee;
}
&amp;.info {
border-color: #90caf9;
color: #e3f2fd;
}
&amp;.warn {
border-color: #ffb74d;
color: #fff3e0;
}
&amp;.danger {
border-color: #ef5350;
color: #ffebee;
}
}
}
[data-scheme="sepia"] {
.notice {
&amp;.info {
border-color: #6a5acd;
color: #3c2f2f;
}
&amp;.warn {
border-color: #e9967a;
color: #5c4033;
}
&amp;.danger {
border-color: #cd5c5c;
color: #7b3f3f;
}
}
}
&lt;/style>
