<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>CSS on yexca'Blog</title><link>https://blog.yexca.net/ja/tags/css/</link><description>Recent content in CSS on yexca'Blog</description><generator>Hugo -- gohugo.io</generator><language>ja</language><copyright>yexca</copyright><lastBuildDate>Sat, 13 Apr 2024 22:06:58 +0800</lastBuildDate><atom:link href="https://blog.yexca.net/ja/tags/css/feed.xml" rel="self" type="application/rss+xml"/><item><title>CSS ボックスモデル</title><link>https://blog.yexca.net/ja/archives/167/</link><pubDate>Sat, 13 Apr 2024 22:06:58 +0800</pubDate><guid>https://blog.yexca.net/ja/archives/167/</guid><description>&lt;div class="notice ">&lt;strong>📢&lt;/strong> この記事は gemini-2.5-flash によって翻訳されました
&lt;/div>
&lt;style lang="scss">
.notice {
padding: 0.75em 1em;
margin: 1em 0;
border-left: 4px solid;
border-radius: 4px;
background-color: var(--card-background-secondary);
color: var(--card-text-color-main);
backdrop-filter: saturate(var(--glass-saturation)) blur(var(--glass-blur));
-webkit-backdrop-filter: saturate(var(--glass-saturation)) blur(var(--glass-blur));
&amp;.default {
border-color: #ccc;
}
&amp;.info {
border-color: #2196f3;
color: #1a237e;
}
&amp;.warn {
border-color: #ff9800;
color: #e65100;
}
&amp;.danger {
border-color: #f44336;
color: #b71c1c;
}
}
[data-scheme="dark"] {
.notice {
&amp;.default {
border-color: #666;
color: #eee;
}
&amp;.info {
border-color: #90caf9;
color: #e3f2fd;
}
&amp;.warn {
border-color: #ffb74d;
color: #fff3e0;
}
&amp;.danger {
border-color: #ef5350;
color: #ffebee;
}
}
}
[data-scheme="sepia"] {
.notice {
&amp;.info {
border-color: #6a5acd;
color: #3c2f2f;
}
&amp;.warn {
border-color: #e9967a;
color: #5c4033;
}
&amp;.danger {
border-color: #cd5c5c;
color: #7b3f3f;
}
}
}
&lt;/style>
&lt;h2 id="表示モード">表示モード
