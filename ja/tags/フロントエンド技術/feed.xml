&lt;thead>
&lt;tr>
&lt;th>説明&lt;/th>
&lt;th>プロパティ&lt;/th>
&lt;/tr>
&lt;/thead>
&lt;tbody>
&lt;tr>
&lt;td>背景色&lt;/td>
&lt;td>background-color&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>背景画像&lt;/td>
&lt;td>background-image&lt;/td>
&lt;/tr>
&lt;tr>
&lt;td>背景画像の繰り返し方&lt;/td>
&lt;td>background-repeat&lt;/td>
&lt;/tr>
